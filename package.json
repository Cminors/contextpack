{
  "name": "contextpack",
  "version": "0.1.0",
  "description": "Build small, explainable task-context packs for JavaScript and TypeScript coding agents.",
  "type": "module",
  "bin": {
    "contextpack": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check": "npm run typecheck && npm run test && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "coding-agent",
    "context-engineering",
    "typescript",
    "codex",
    "claude-code",
    "cursor"
  ],
  "license": "MIT",
  "overrides": {
    "esbuild": "0.28.1"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "fast-glob": "^3.3.3",
    "gpt-tokenizer": "^3.4.0",
    "ignore": "^7.0.6",
    "typescript": "5.9.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "vitest": "^4.1.10"
  }
}
